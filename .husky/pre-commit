#!/usr/bin/env sh
# pre-commit hook (heredado de mapi v0.x D-059, D-060, D-062)
#
# Bloquea commits que rompan: formato (prettier), estilo (eslint),
# o tipos (tsc). Aplica a los 3 apps (mapi, web, kiro).
#
# NO usar `git commit --no-verify`. Si algo falla, investigar el root
# cause, no bypassear.

set -e

echo "→ lint-staged (prettier + eslint sobre archivos staged)"
npx lint-staged

echo "→ typecheck en cada app modificada"
npm run typecheck

echo "✓ pre-commit OK"
