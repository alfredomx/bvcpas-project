# Core de mapi_v2 — variables de entorno.
# Copia este archivo a `.env` (gitignoreado) y ajusta los valores.
# Solo van las vars que el core ya lee; crecen con cada pieza de infra.

NODE_ENV=local
PORT=4200
LOG_LEVEL=info

# Postgres LOCAL: reusa el contenedor bvcpas-postgres-local (docker-compose.local.yml),
# base propia mapi_v2_local. En prod estas vars viven en el panel de deploy.
DATABASE_URL=postgresql://mapi:mapi_local_password@localhost:5433/mapi_v2_local

# Redis LOCAL: reusa el contenedor bvcpas-redis-local (:6379). Índice db 3 para
# mapi_v2, distinto del de mapi (índice 1 local) — no colisionan las colas.
REDIS_URL=redis://localhost:6379/3

# Auth slim: secreto HMAC con el que el AdminGuard verifica el JWT (mín. 32 chars).
# Genera uno: node -e "console.log(require('node:crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=cambia-esto-por-un-secreto-de-al-menos-32-caracteres
# JWT admin de larga vida para curl/pruebas (firmado con JWT_SECRET). Opcional, no lo lee el core.
# Genera uno: node -e "console.log(require('jsonwebtoken').sign({sub:'admin',role:'admin'}, process.env.JWT_SECRET, {expiresIn:'3650d'}))"
ADMIN_JWT_SECRET=

# Encryption (core v0.3.0): clave AES-256, 32 bytes en base64. La usan los plugins
# que guardan secretos (intuit tokens, etc.). En prod = la misma key de mapi viejo
# (para que la migración v0.2.0 desencripte). Genera una:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Intuit (plugin) — credenciales de la app de Intuit Developer (dev: BV CPAs Dev).
# El registro valida estas vars al boot; sin ellas el core no arranca.
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_REDIRECT_URI=https://dev.alfredo.mx/v1/intuit/oauth/callback
INTUIT_ENVIRONMENT=sandbox
INTUIT_MINOR_VERSION=75
