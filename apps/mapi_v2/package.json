{
  "name": "mapi_v2",
  "version": "0.1.0",
  "description": "mapi_v2 - host (core + plugins + pipes). Deps compartidas; el core compila y monta los plugins/pipes del registro.",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "node -e \"const{rmSync}=require('node:fs');['dist','tsconfig.tsbuildinfo','tsconfig.build.tsbuildinfo'].forEach(p=>rmSync(p,{recursive:true,force:true}))\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/core/src/main.js",
    "start:prod": "node dist/core/src/main.js",
    "dev:serve": "tsc-alias -p tsconfig.build.json && node dist/core/src/main.js",
    "start:dev": "npm run clean && tsc-watch -p tsconfig.build.json --onSuccess \"npm run dev:serve\"",
    "lint": "eslint \"core/src/**/*.ts\" \"plugins/**/src/**/*.ts\" \"pipes/**/src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"core/src/**/*.ts\" \"plugins/**/src/**/*.ts\" \"pipes/**/src/**/*.ts\" --no-error-on-unmatched-pattern --fix",
    "format": "prettier --write --no-error-on-unmatched-pattern \"core/src/**/*.ts\" \"plugins/**/src/**/*.ts\" \"pipes/**/src/**/*.ts\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"core/src/**/*.ts\" \"plugins/**/src/**/*.ts\" \"pipes/**/src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "test": "jest --config ./test/_setup/jest.config.ts",
    "test:watch": "jest --config ./test/_setup/jest.config.ts --watch",
    "test:cov": "jest --config ./test/_setup/jest.config.ts --coverage",
    "test:e2e": "jest --config ./test/_setup/jest-e2e.json --runInBand --forceExit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "bullmq": "^5.78.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "tsc-alias": "^1.8.0",
    "tsc-watch": "^6.2.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
