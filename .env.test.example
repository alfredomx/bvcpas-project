# =====================================================================
# bvcpas-project — plantilla de variables para tests
#
# Copiar a `apps/mapi/.env.test` y rellenar.
# NUNCA commitear .env.test real.
#
# Tests usan DB y Redis dedicados (db=2) para no chocar con dev local (db=1)
# ni con producción (db=0).
# =====================================================================

NODE_ENV=test
PORT=4000

# Postgres - DB separada para tests
POSTGRES_USER=mapi
POSTGRES_PASSWORD=mapi_local_password
POSTGRES_DB=mapi_test
DATABASE_URL=postgresql://mapi:mapi_local_password@localhost:5433/mapi_test

# Redis - db=2 para tests
REDIS_URL=redis://localhost:6379/2

# Loki silenciado en tests
LOKI_URL=

# Auth - valores dummy para tests
JWT_SECRET=test_jwt_secret_at_least_32_chars_long_for_tests_only
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Intuit - mocks en tests, no se conecta a Intuit real
INTUIT_ENVIRONMENT=sandbox
INTUIT_MINOR_VERSION=75
INTUIT_CLIENT_ID=test_client_id
INTUIT_CLIENT_SECRET=test_client_secret
INTUIT_REDIRECT_URI=http://localhost:4000/v1/intuit/callback

# Bridge - mock en tests
BRIDGE_SHARED_SECRET=test_bridge_secret_at_least_32_chars_long_for_tests_only
