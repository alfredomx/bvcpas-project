# =====================================================================
# bvcpas-project — plantilla de variables de entorno
#
# Copiar a `apps/mapi/.env` y rellenar valores reales.
# NUNCA commitear .env real (está en .gitignore).
#
# Schema de validación: apps/mapi/src/core/config/config.schema.ts.
# La app NO arranca si falta una variable requerida o tiene formato inválido.
#
# Cada módulo agrega sus variables al schema cuando entre. En Fundación (P0)
# solo se validan las marcadas con [P0]. El resto vive aquí esperando que su
# módulo entre.
# =====================================================================

# ---------- Runtime [P0] ----------
# Valores: local | test | production
# - local: dev nativo en PC del operador (`npm run start:dev`).
# - test: tests con `.env.test`.
# - production: container Docker en Coolify (Coolify inyecta vars desde panel).
NODE_ENV=local

# Puerto del backend mapi
PORT=4000

# Nivel de logger pino
LOG_LEVEL=debug

# URL pública (Cloudflare Tunnel u otra). Opcional. Si no se setea, el banner
# de startup solo muestra localhost.
PUBLIC_URL=

# ---------- Postgres [P0] ----------
# Naming convention de DBs:
#   mapi_local  → entorno local (este archivo)
#   mapi_test   → tests (ver .env.test.example)
#   mapi_prod   → producción Coolify (NO usar en local)
POSTGRES_USER=mapi
POSTGRES_PASSWORD=mapi_local_password
POSTGRES_DB=mapi_local
POSTGRES_PORT=5433
DATABASE_URL=postgresql://mapi:mapi_local_password@localhost:5433/mapi_local

# ---------- Redis ----------
# Heredado D-137 mapi v0.x: db separadas por entorno para evitar que workers
# compitan por la misma queue de BullMQ.
#   db=0 → producción Coolify
#   db=1 → local (este archivo)
#   db=2 → tests
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/1

# ---------- Loki (logs centralizados, opcional) ----------
# Si no se setea, los logs solo van a stdout. Cuando se monte Loki en Coolify,
# este URL apuntará al servicio interno.
LOKI_URL=

# ---------- Auth (entra cuando AuthModule entre) ----------
# JWT_SECRET: mínimo 32 chars. Generar con: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES_IN=7d
# ENCRYPTION_KEY: 32 bytes base64 (AES-256-GCM). Generar con: openssl rand -base64 32
ENCRYPTION_KEY=

# ---------- Intuit OAuth (entra con P1 Intuit Core) ----------
# 3 sets de credenciales DISTINTOS, NO mezclar:
#
#   1. App "BV CPAs, PLLC" (PRODUCCIÓN): la usa Coolify (mapi.alfredo.mx o el
#      subdominio que asignes). NO va en este archivo. Vive solo en panel Coolify.
#
#   2. App "BV CPAs Dev" (DESARROLLO LOCAL): la usa este archivo.
#      Redirect URI registrado: https://dev.alfredo.mx/v1/intuit/callback
#
#   3. Sandbox (juguete): no se usa.
INTUIT_ENVIRONMENT=production
INTUIT_MINOR_VERSION=75
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_REDIRECT_URI=https://dev.alfredo.mx/v1/intuit/callback

# ---------- Bridge WebSocket (entra con P2 Plugin v2) ----------
# Shared secret entre mapi y plugin Chrome (kiro). Mínimo 32 chars.
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
BRIDGE_SHARED_SECRET=

# ---------- Cloudflare (opcional, gestión de túneles) ----------
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
